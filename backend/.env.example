NODE_ENV=development
PORT=5000

# Comma-separated list. Example: http://localhost:5173,https://shortify.com
CORS_ORIGINS=http://localhost:5173

# MongoDB Atlas connection string in production.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/shortify

# Security and operational settings
REQUEST_BODY_LIMIT=10kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOG_LEVEL=info

# Redis cache. Leave empty locally if Redis is not configured.
REDIS_URL=
REDIRECT_CACHE_TTL_SECONDS=86400

# JWT authentication
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cookies
REFRESH_TOKEN_COOKIE_NAME=shortify_refresh_token
COOKIE_DOMAIN=

# Password reset
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=15
CLIENT_PASSWORD_RESET_URL=http://localhost:5173/reset-password

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback
GOOGLE_OAUTH_STATE_COOKIE_NAME=shortify_google_oauth_state

# React OAuth redirects
CLIENT_OAUTH_SUCCESS_URL=http://localhost:5173/auth/oauth/callback
CLIENT_OAUTH_FAILURE_URL=http://localhost:5173/login
