NODE_ENV=development
PORT=5000

# Comma-separated allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.example

# MongoDB Atlas connection string in production.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/shortify

# Security and operational settings
REQUEST_BODY_LIMIT=10kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOG_LEVEL=info
HEALTHCHECK_HOST=127.0.0.1
HEALTHCHECK_PATH=/api/v1/health

# Redis cache. Use Redis Cloud in production.
REDIS_URL=
REDIRECT_CACHE_TTL_SECONDS=86400

# JWT authentication
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_TOKEN_ROTATION_GRACE_SECONDS=10

# Cookies
REFRESH_TOKEN_COOKIE_NAME=shortify_refresh_token
COOKIE_DOMAIN=

# Password reset
CLIENT_URL=http://localhost:3000
CLIENT_VERIFY_EMAIL_URL=http://localhost:3000/verify-email
EMAIL_VERIFICATION_TOKEN_EXPIRES_MINUTES=60
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=15
CLIENT_PASSWORD_RESET_URL=http://localhost:3000/reset-password

# Transactional email
RESEND_API_KEY=replace-with-resend-api-key
EMAIL_FROM=Shortify <noreply@your-domain.example>

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback
GOOGLE_OAUTH_STATE_COOKIE_NAME=shortify_google_oauth_state

# React OAuth redirects
CLIENT_OAUTH_SUCCESS_URL=http://localhost:3000/auth/callback
CLIENT_OAUTH_FAILURE_URL=http://localhost:3000/login
