# Docker Compose host/container ports
BACKEND_HOST_PORT=5000
BACKEND_CONTAINER_PORT=5000
FRONTEND_HOST_PORT=3000
FRONTEND_CONTAINER_PORT=8080
REDIS_HOST_PORT=6379
REDIS_CONTAINER_PORT=6379

# Backend container health check
BACKEND_HEALTHCHECK_HOST=127.0.0.1
BACKEND_HEALTHCHECK_PATH=/api/v1/health

# Frontend build-time variables for Docker builds
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_SHORT_LINK_BASE_URL=http://localhost:5000
